@page "/Error"

<PageTitle>Error</PageTitle>

<div class="rounded-[2rem] border border-rose-200 bg-white p-8 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-rose-700">Something went wrong</p>
    <h1 class="mt-2 text-3xl font-semibold text-slate-900">An unexpected error occurred.</h1>
    <p class="mt-3 text-sm leading-6 text-slate-600">Try returning to <a href="/fields" class="font-semibold text-emerald-700 hover:text-emerald-900">My Fields</a> and submitting again.</p>
</div>
