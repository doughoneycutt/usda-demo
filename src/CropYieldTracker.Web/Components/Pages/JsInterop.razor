@page "/js-interop"
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<PageTitle>JS Interop Demo</PageTitle>

<div class="space-y-8">
    <section>
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-rose-700">JS Interop Demo</p>
        <h2 class="mt-2 text-3xl font-semibold text-slate-900">Local storage and JavaScript-to-.NET callbacks</h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">This page reads a local storage counter on startup, initializes it to zero if it does not exist, and lets JavaScript increment the value before calling back into the Blazor component to update the UI.</p>
    </section>

    <section class="max-w-4xl rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
        <div class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr] lg:items-start">
            <div>
                <h3 class="text-2xl font-semibold text-slate-900">Browser storage counter</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">Startup reads the current local storage value through JS interop. The increment button does not update the value locally in C#; it calls JavaScript, JavaScript writes local storage, and JavaScript calls back into .NET with the new value.</p>

                <div class="mt-6 rounded-3xl bg-rose-50 px-5 py-5 ring-1 ring-rose-100">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-rose-700">Current local storage value</p>
                    <div class="mt-2 text-5xl font-semibold text-slate-900">@_counterValue.ToString(CultureInfo.InvariantCulture)</div>
                    <p class="mt-3 text-sm text-slate-600">Storage key: <span class="font-mono text-slate-900">@StorageKey</span></p>
                </div>
            </div>

            <div class="rounded-3xl bg-slate-900 px-6 py-6 text-white shadow-lg">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-rose-200">Interop actions</p>
                <h4 class="mt-2 text-xl font-semibold">JS owns the write</h4>
                <p class="mt-3 text-sm leading-6 text-slate-300">Use these actions to read from storage or increment the value via JavaScript.</p>
                <div class="mt-6 space-y-3">
                    <button type="button" @onclick="RefreshFromStorageAsync" class="w-full rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-rose-100">
                        Read current value
                    </button>
                    <button type="button" @onclick="IncrementViaJsAsync" class="w-full rounded-full bg-amber-300 px-5 py-3 text-sm font-semibold text-slate-950 ring-1 ring-amber-200 transition hover:bg-amber-200">
                        Increment through JS
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="mt-6 rounded-3xl border border-sky-200 bg-sky-50 px-5 py-4 text-sm font-medium text-sky-900">
                @_statusMessage
            </div>
        }
    </section>
</div>

@code {
    private const string StorageKey = "crop-yield-tracker-jsinterop-counter";

    private DotNetObjectReference<JsInterop>? _dotNetReference;
    private int _counterValue;
    private string? _statusMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);
        _counterValue = await JSRuntime.InvokeAsync<int>("cropYieldInterop.ensureCounterInitialized", StorageKey, 0);
        _statusMessage = "Counter initialized from local storage.";
        StateHasChanged();
    }

    private async Task RefreshFromStorageAsync()
    {
        _counterValue = await JSRuntime.InvokeAsync<int>("cropYieldInterop.readCounter", StorageKey);
        _statusMessage = "Counter refreshed from local storage through JavaScript.";
    }

    private async Task IncrementViaJsAsync()
    {
        if (_dotNetReference is null)
        {
            return;
        }

        _statusMessage = "Calling JavaScript to update local storage and notify .NET...";
        await JSRuntime.InvokeVoidAsync("cropYieldInterop.incrementCounterAndNotify", StorageKey, _dotNetReference);
    }

    [JSInvokable]
    public Task SetCounterFromJs(int updatedValue)
    {
        _counterValue = updatedValue;
        _statusMessage = "JavaScript updated local storage and called back into .NET with the new value.";
        StateHasChanged();
        return Task.CompletedTask;
    }

    public ValueTask DisposeAsync()
    {
        _dotNetReference?.Dispose();
        return ValueTask.CompletedTask;
    }
}

