@page "/"
@inject IFieldService FieldService

<PageTitle>Crop Yield Tracker</PageTitle>

<div class="space-y-8">
    <section class="rounded-[2rem] bg-gradient-to-br from-emerald-900 via-emerald-700 to-amber-500 px-6 py-8 text-white shadow-xl">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-100">Crop Yield Tracker</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight">Server-rendered field and crop tracking built for a clean USDA-style demo.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-emerald-50">Use the left navigation to manage fields, enter crop yields by field, and review a simple reporting view. The data layer is mocked in-memory and also exposed through a separate REST API project.</p>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
        <StatCard Title="Fields" Value="@_fieldCount.ToString(CultureInfo.InvariantCulture)" Description="Tracked fields in the mock repository." />
        <StatCard Title="Crops" Value="@_cropCount.ToString(CultureInfo.InvariantCulture)" Description="Crop entries tied back to fields." />
        <StatCard Title="Production" Value="@_production.ToString("N0", CultureInfo.InvariantCulture)" Description="Total mock production across all crop entries." />
    </section>
</div>

@code {
    private int _fieldCount;
    private int _cropCount;
    private decimal _production;

    protected override async Task OnInitializedAsync()
    {
        var fields = await FieldService.GetFieldsAsync();
        var crops = await FieldService.GetCropsAsync();
        _fieldCount = fields.Count;
        _cropCount = crops.Count;
        _production = crops.Sum(crop => crop.TotalProduction);
    }
}
