@using System.Globalization

<section class="space-y-4">
    @foreach (var report in Reports)
    {
        <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h3 class="text-xl font-semibold text-slate-900">@report.FieldName</h3>
                    <p class="text-sm text-slate-600">Total production: @report.TotalProduction.ToString("N0", CultureInfo.InvariantCulture)</p>
                </div>
                <a href="/crops?fieldId=@report.FieldId" class="text-sm font-semibold text-sky-700 hover:text-sky-900">Manage crops</a>
            </div>

            <div class="mt-5 space-y-4">
                @foreach (var crop in report.Crops)
                {
                    <div>
                        <div class="mb-1 flex items-center justify-between text-sm text-slate-700">
                            <span class="font-medium text-slate-900">@crop.CropName</span>
                            <span>@crop.TotalProduction.ToString("N0", CultureInfo.InvariantCulture) @crop.Unit</span>
                        </div>
                        <div class="h-4 rounded-full bg-stone-200">
                            <div class="h-4 rounded-full bg-sky-500" style="@GetBarStyle(crop.PercentOfField)"></div>
                        </div>
                    </div>
                }
            </div>
        </article>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<ComponentFieldReportModel> Reports { get; set; } = [];

    private static string GetBarStyle(decimal percentOfField)
    {
        return $"width: {percentOfField.ToString(CultureInfo.InvariantCulture)}%";
    }
}
