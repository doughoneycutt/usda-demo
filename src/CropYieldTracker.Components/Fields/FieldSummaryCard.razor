@using System.Globalization

<article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-2">
            <div class="flex items-center gap-3">
                <h3 class="text-xl font-semibold text-slate-900">@Field.Name</h3>
                <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">@Field.County</span>
            </div>
            <p class="text-sm text-slate-600">@Field.SoilType soil Ģ @Field.IrrigationType irrigation</p>
        </div>

        <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
            <div class="rounded-2xl bg-stone-50 px-4 py-3">
                <div class="text-xs uppercase tracking-[0.2em] text-slate-500">Field Acres</div>
                <div class="mt-1 text-lg font-semibold text-slate-900">@Field.TotalAcres.ToString("N0", CultureInfo.InvariantCulture)</div>
            </div>
            <div class="rounded-2xl bg-stone-50 px-4 py-3">
                <div class="text-xs uppercase tracking-[0.2em] text-slate-500">Cropped Acres</div>
                <div class="mt-1 text-lg font-semibold text-slate-900">@Field.ReportedCropAcres.ToString("N0", CultureInfo.InvariantCulture)</div>
            </div>
            <div class="rounded-2xl bg-stone-50 px-4 py-3">
                <div class="text-xs uppercase tracking-[0.2em] text-slate-500">Crop Count</div>
                <div class="mt-1 text-lg font-semibold text-slate-900">@Field.Crops.Count</div>
            </div>
            <div class="rounded-2xl bg-stone-50 px-4 py-3">
                <div class="text-xs uppercase tracking-[0.2em] text-slate-500">Production</div>
                <div class="mt-1 text-lg font-semibold text-slate-900">@Field.Crops.Sum(crop => crop.TotalProduction).ToString("N0", CultureInfo.InvariantCulture)</div>
            </div>
        </div>
    </div>

    @if (Field.Crops.Count > 0)
    {
        <div class="mt-4 flex flex-wrap gap-2">
            @foreach (var crop in Field.Crops)
            {
                <span class="rounded-full bg-emerald-50 px-3 py-1 text-sm font-medium text-emerald-800">@crop.CropName: @crop.TotalProduction.ToString("N0", CultureInfo.InvariantCulture) @crop.Unit</span>
            }
        </div>
    }

    <div class="mt-5 flex justify-end">
        <a href="/fields?editId=@Field.Id" class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">Edit field</a>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public ComponentFieldModel Field { get; set; } = default!;
}
